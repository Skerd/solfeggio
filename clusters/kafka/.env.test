# Kafka client authentication (SASL/PLAIN)
KAFKA_USERNAME=username
KAFKA_PASSWORD=password

# Inter-broker authentication (optional, defaults shown)
# KAFKA_BROKER_USERNAME=admin
# KAFKA_BROKER_PASSWORD=broker-secret

# Optional: comma-separated IPs added to every TLS cert SAN (e.g. public server IP)
TLS_EXTRA_SAN_IPS=111.111.111.111
# TLS keystore/truststore password (optional, default: changeit)
# KAFKA_SSL_STORE_PASSWORD=changeit
