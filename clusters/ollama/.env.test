# Ollama cluster configuration (local LLM for the AI-assistant chat)
OLLAMA_HOST=ollama
OLLAMA_INTERNAL_PORT=11434
OLLAMA_EXTERNAL_PORT=11434
OLLAMA_IMAGE=ollama/ollama:latest

# Model tag to pull on startup and serve to the assistant brain.
OLLAMA_MODEL=llama3.1:8b

# Optional generation tuning surfaced into the Maestro .env when enabled.
AI_ASSISTANT_TIMEOUT_MS=60000
AI_ASSISTANT_TEMPERATURE=0.7
