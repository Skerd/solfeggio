# Nginx gateway cluster configuration
NGINX_IMAGE=nginx:1.27-alpine
NGINX_LISTEN_PORT=80

FRONTEND_UPSTREAM_HOST=frontend
FRONTEND_UPSTREAM_PORT=80
API_UPSTREAM_HOST=maestroApi
API_UPSTREAM_PORT=81
WEBSOCKET_UPSTREAM_HOST=maestroWebsocket
WEBSOCKET_UPSTREAM_PORT=82

PROXY_CONNECT_TIMEOUT=1000s
PROXY_SEND_TIMEOUT=1000s
PROXY_READ_TIMEOUT=1000s
WEBSOCKET_READ_TIMEOUT=3600s
WEBSOCKET_SEND_TIMEOUT=3600s
CLIENT_MAX_BODY_SIZE=2G
STATIC_ASSETS_EXPIRES=30d

API_LOAD_BALANCE_METHOD=round_robin
WEBSOCKET_LOAD_BALANCE_METHOD=ip_hash
FRONTEND_LOAD_BALANCE_METHOD=round_robin

DOCKER_INTERNAL_NETWORK=arpeggio_internal_network
